# ─────────────────────────────────────────────────────────────────────────────
# Subagent Virtual Employee System — environment configuration
#
# EVERYTHING here is OPTIONAL. With no .env at all the app runs fully offline
# (deterministic reasoning engine + built-in text extraction). Copy this file
# to `.env` and fill in only what you want to enable.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3001
# SQLite database file (':memory:' allowed; the smoke tests use a throwaway path)
# DB_FILE=./server/data/app.db

# ── Public-deploy hardening（公網部署加固；本機自用全部不用管）──────────────
# Bind address. Default 127.0.0.1 = only this machine can reach the app.
# Set 0.0.0.0 to expose on the network (Docker sets this) — then ALSO set
# AUTH_TOKEN, or anyone who can reach the port can use your brains and data.
# HOST=127.0.0.1
# Shared access token. When set, every /api request must present it
# (Authorization: Bearer …, X-Auth-Token, or the veemp_token cookie —
# the web UI prompts once and remembers).
# AUTH_TOKEN=
# Cross-origin allow-list. Default: none (the client is served same-origin;
# dev uses the Vite proxy). Comma-separated origins if you really need it.
# CORS_ORIGINS=https://your.host
# Per-IP rate limit on /api: RATE_LIMIT requests per RATE_WINDOW_SEC seconds.
# Defaults 600/300. RATE_LIMIT=0 disables.
# RATE_LIMIT=600
# RATE_WINDOW_SEC=300

# ── Reasoning brain ──────────────────────────────────────────────────────────
# Which brain drives the agents. Also switchable in the UI at runtime.
#   google      — Google Gen AI API key (below)
#   claude-cli  — your Claude Pro/Max subscription via the official `claude` CLI
#   codex-cli   — your ChatGPT Plus/Pro subscription via the official `codex` CLI
# LLM_PROVIDER=google

# --- google (API key) ---
# Get one at https://aistudio.google.com/apikey . Without it, the app uses the
# offline deterministic engine. GEMINI_API_KEY is preferred; GOOGLE_API_KEY works too.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemma-4-31b-it
# Suppress Gemma-4 thinking tokens ('MINIMAL' is the only accepted level; '' = model default)
# LLM_THINKING_LEVEL=MINIMAL

# --- claude-cli (subscription; single-user, local machine only) ---
# CLAUDE_MODEL=sonnet          # sonnet | opus | haiku | full model id
# CLAUDE_CLI=claude
# CLAUDE_CODE_OAUTH_TOKEN=      # optional long-lived token from `claude setup-token`
# CLAUDE_CLI_TIMEOUT_SEC=300
# CLAUDE_CLI_MAX_CONCURRENT=2

# --- codex-cli (subscription; single-user, local machine only) ---
# Leave CODEX_MODEL unset to use your ACCOUNT's default model (recommended —
# ChatGPT-subscription auth rejects model ids it doesn't offer).
# CODEX_MODEL=
# CODEX_CLI=codex
# CODEX_CLI_TIMEOUT_SEC=300
# CODEX_CLI_MAX_CONCURRENT=2

# ── Web search (agent tool) ──────────────────────────────────────────────────
# Enables the web_search tool + autonomous research. Get a key at https://tavily.com .
# Also gated by an in-app toggle (topbar 🌐 網路搜尋). Without a key it's simply off.
# TAVILY_API_KEY=
# WEB_SEARCH_ENDPOINT=https://api.tavily.com/search
# WEB_SEARCH_DEPTH=advanced          # advanced | basic  (advanced = richer, 2 credits/query)
# WEB_SEARCH_CHUNKS_PER_SOURCE=3
# WEB_SEARCH_MAX_RESULTS=5
# WEB_SEARCH_TIMEOUT_SEC=20

# ── Agent tools ──────────────────────────────────────────────────────────────
# AGENT_MAX_TOOL_CALLS=3             # per meeting/dialogue turn
# RESEARCH_MAX_TOOL_CALLS=6          # per autonomous-research run

# ── Output length ceilings (headroom, not targets) ───────────────────────────
# The model stops when it's done — raising these only costs tokens when the
# model actually writes more. Raise if deliverables ever feel clipped.
# LLM_TURN_MAX_TOKENS=2048           # meeting speeches / goal task turns
# LLM_DOC_MAX_TOKENS=8192            # reports, research, 1on1 replies (documents)
# LLM_SUMMARY_MAX_TOKENS=4096        # memory/1on1 distillation, consolidation

# ── Retrieval / chunking ─────────────────────────────────────────────────────
# CHUNK_SIZE=480                     # ~chars per knowledge chunk
# CHUNK_OVERLAP=60
# RETRIEVAL_TOP_K=4
# MAX_CHUNKS_PER_DOC=2000            # cap chunks per document (excess is dropped + noted)

# ── Hybrid semantic retrieval (optional; D2) ─────────────────────────────────
# OFF by default → pure BM25/FTS keyword search (zero extra deps). When on,
# retrieval fuses BM25 (exact terms) with local vector cosine (paraphrase /
# near-synonym) via Reciprocal Rank Fusion. Enable in TWO steps:
#   1) run `npm run setup:embeddings`  (installs the model + back-indexes chunks)
#   2) set EMBEDDINGS_ENABLED=1 and restart
# If the model or its dependency can't load, it silently falls back to pure BM25.
# EMBEDDINGS_ENABLED=                 # '1' turns hybrid retrieval on
# EMBEDDINGS_MODEL=Xenova/multilingual-e5-small   # local transformers.js model (multilingual)
# EMBEDDINGS_RRF_K=60                 # RRF constant (larger = flatter fusion)
# EMBEDDINGS_CANDIDATES=40            # candidates each retriever contributes to fusion
# EMBEDDINGS_BATCH_SIZE=32            # texts embedded per model call during indexing

# ── Document ingestion (MarkItDown) ──────────────────────────────────────────
# Optional Python helper for PDF/DOCX/PPTX/XLSX/CSV → Markdown. Run `npm run
# setup:markitdown` to install into a project-local .venv. Text formats
# (TXT/MD/HTML) work without it.
# MARKITDOWN_PYTHON=                 # explicit interpreter; else auto-probes .venv then python3
# UPLOAD_MAX_BYTES=15728640          # 15 MiB
# MARKITDOWN_TIMEOUT_SEC=120
# MARKITDOWN_DISABLE=                # '1' forces the built-in JS fallback

# ── Meeting memory ───────────────────────────────────────────────────────────
# MEETING_MEMORY_DISABLE=            # '1' disables post-meeting memory distillation
# Memory consolidation (D3): once an employee accumulates this many memory docs,
# they're merged into one de-duplicated memory (originals archived, not deleted).
# MEMORY_CONSOLIDATE_THRESHOLD=12    # min active memory docs to auto-consolidate
# MEMORY_CONSOLIDATE_DISABLE=        # '1' disables consolidation (auto + manual)
