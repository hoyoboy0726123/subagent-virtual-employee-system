{
  "name": "subagent-virtual-employee-system",
  "version": "1.0.0",
  "private": true,
  "description": "A digital virtual-employee system: create AI employee roles, give them knowledge, run meetings, and assign collaborative goals.",
  "type": "module",
  "scripts": {
    "seed": "node server/src/seed.js",
    "dev": "concurrently -n api,web -c blue,green \"npm:dev:api\" \"npm:dev:web\"",
    "dev:api": "node --watch server/src/index.js",
    "dev:web": "vite --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "start": "node server/src/index.js",
    "serve": "npm run build && npm run start",
    "test": "node server/test/smoke.mjs"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "vite": "^6.0.7"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
